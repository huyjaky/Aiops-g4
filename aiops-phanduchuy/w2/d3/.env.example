# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Custom OpenAI Base URL (e.g. for proxy, local models or gateways)
OPENAI_BASE_URL=https://api.xah.io/v1

# Optional: OpenAI Model to use (default: gpt-4o-mini)
OPENAI_MODEL=gpt-5.4-mini

# Optional: AIOPS pipeline feature flag to toggle LLM usage (default: true)
# Set to 'false' to bypass LLM and fallback to graph+retrieval mode offline.
AIOPS_USE_LLM=true
