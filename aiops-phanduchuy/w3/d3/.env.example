# ==========================================
# HuyPD AIOps Mini-Platform - Configurations & Hyperparameters
# ==========================================

# 1. Stack and Pipeline Ports
PIPELINE_PORT=8000
CHECKOUT_PORT=8080
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# 2. Service URLs
PIPELINE_URL=http://localhost:8000
CHECKOUT_SVC_URL=http://localhost:8080
PROM_URL=http://localhost:9090

# 3. Anomaly Detection Hyperparameters
ANOMALY_THRESHOLD_SIGMA=3.0

# 4. Correlation Hyperparameters
CORRELATION_WINDOW_SECONDS=120
CORRELATION_MAX_HOP=2

# 5. LLM / Enrichment Settings
AIOPS_USE_LLM=true
OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1

# 6. Chaos Engineering Settings
COOLDOWN_SECONDS=5
STATE_FILE=/app/shared/state.json

# 7. Business & Cost Model Hyperparameters
AIOPS_MONTHLY_COST=20000
EXPECTED_MTTR_REDUCTION_PCT=0.4
DOWNTIME_COST_PER_HOUR=50000
